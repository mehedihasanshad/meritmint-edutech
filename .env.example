# Session signing secret (required, min 16 chars). Generate a strong random one.
# Local dev can use any 16+ char string. Production: use a real secret.
AUTH_SECRET=replace-me-with-32-random-chars-here

# Turso (libSQL) — required for production / Vercel.
# Leave blank locally to use ./data/meritmint.db as a local SQLite file.
#
# To set up:
#   1. Install Turso CLI:  curl -sSfL https://get.tur.so/install.sh | bash
#   2. Sign up:            turso auth signup
#   3. Create db:          turso db create meritmint
#   4. Get URL:            turso db show meritmint --url
#   5. Mint token:         turso db tokens create meritmint
#
# Then paste both below (and add to Vercel project env vars).
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Comma-separated list of usernames that can access the /admin area.
# Create an account with that username, then log in — you'll see the admin link.
ADMIN_USERNAMES=
